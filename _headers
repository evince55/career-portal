/css/*
  Cache-Control: public, max-age=31536000
  Content-Type: text/css

/js/*
  Cache-Control: public, max-age=31536000
  Content-Type: application/javascript

/icons/*
  Cache-Control: public, max-age=31536000
  Content-Type: image/png

/config/*
  Cache-Control: public, max-age=600
  Content-Type: application/json
